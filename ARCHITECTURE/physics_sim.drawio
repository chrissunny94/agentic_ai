<mxfile host="app.diagrams.net">
  <diagram id="physim_arch" name="PhysSim Agentic Architecture">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ══════════════════════════════════════════
             USER
        ══════════════════════════════════════════ -->
        <mxCell id="user" value="User / Researcher"
          style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="40" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             AGENTIC CONTROLLER (outer)
        ══════════════════════════════════════════ -->
        <mxCell id="ctrl_outer" value="Agentic Controller (app.py)"
          style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;startSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="180" y="230" width="280" height="280" as="geometry"/>
        </mxCell>

        <!-- inner: model router -->
        <mxCell id="model_router" value="&lt;b&gt;Model router&lt;/b&gt;&lt;br&gt;Gemini · GPT-4o · Claude&lt;br&gt;Grok · Ollama (local)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="ctrl_outer">
          <mxGeometry x="20" y="50" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- inner: memory.md -->
        <mxCell id="memory" value="&lt;b&gt;memory.md&lt;/b&gt;&lt;br&gt;Project facts · API signatures&lt;br&gt;Forbidden libs · hot-reloaded"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;"
          vertex="1" parent="ctrl_outer">
          <mxGeometry x="20" y="130" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- inner: fix loop -->
        <mxCell id="fix_loop" value="&lt;b&gt;Fix loop × 3&lt;/b&gt;&lt;br&gt;Rules reminder on every retry&lt;br&gt;Full message history passed"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="ctrl_outer">
          <mxGeometry x="20" y="210" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             LLM PROVIDERS
        ══════════════════════════════════════════ -->
        <mxCell id="llm_outer" value="LLM Providers"
          style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;startSize=30;"
          vertex="1" parent="1">
          <mxGeometry x="580" y="100" width="200" height="230" as="geometry"/>
        </mxCell>

        <mxCell id="llm_gemini" value="Gemini 2.5 Flash"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
          vertex="1" parent="llm_outer">
          <mxGeometry x="15" y="40" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="llm_gpt" value="GPT-4o (OpenAI)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="llm_outer">
          <mxGeometry x="15" y="80" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="llm_claude" value="Claude Sonnet (Anthropic)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;"
          vertex="1" parent="llm_outer">
          <mxGeometry x="15" y="120" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="llm_grok" value="Grok 3 Fast (xAI)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;"
          vertex="1" parent="llm_outer">
          <mxGeometry x="15" y="160" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="llm_ollama" value="Ollama — qwen2.5-coder (local)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;"
          vertex="1" parent="llm_outer">
          <mxGeometry x="15" y="200" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             C++ PHYSICS ENGINE
        ══════════════════════════════════════════ -->
        <mxCell id="cpp_outer" value="Physics Engine (C++)"
          style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;startSize=30;dashed=1;"
          vertex="1" parent="1">
          <mxGeometry x="580" y="370" width="200" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="cpp_main" value="main.cpp (LLM-generated)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="cpp_outer">
          <mxGeometry x="15" y="40" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cpp_anim" value="animation.cpp + animation.hpp"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="cpp_outer">
          <mxGeometry x="15" y="80" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cpp_plots" value="plots.cpp + plots.hpp"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="cpp_outer">
          <mxGeometry x="15" y="120" width="170" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cpp_cmake" value="CMake → sim binary"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;"
          vertex="1" parent="cpp_outer">
          <mxGeometry x="15" y="160" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             SIMULATION OUTPUT
        ══════════════════════════════════════════ -->
        <mxCell id="output" value="Simulation Output&lt;br&gt;stdout · JSON sentinels&lt;br&gt;---ANIMATION_DATA--- · ---PLOT_DATA---"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="590" y="590" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             WEB UI
        ══════════════════════════════════════════ -->
        <mxCell id="webui" value="&lt;b&gt;Web UI (index.html)&lt;/b&gt;&lt;br&gt;Canvas animation · Chart.js plots&lt;br&gt;Model selector · Memory editor"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="180" y="590" width="280" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             STATIC FILES
        ══════════════════════════════════════════ -->
        <mxCell id="static" value="static/&lt;br&gt;style.css · main.js"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="180" y="700" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="memory_file" value="memory.md&lt;br&gt;(project root)"
          style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;size=15;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="470" width="100" height="70" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════
             ARROWS
        ══════════════════════════════════════════ -->

        <!-- User → Controller -->
        <mxCell id="e1" value="prompt + model"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;"
          edge="1" source="user" target="ctrl_outer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Controller → LLM providers -->
        <mxCell id="e2" value="system instr. + history"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;"
          edge="1" source="ctrl_outer" target="llm_outer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- LLM → Controller (generated code) -->
        <mxCell id="e3" value="generated C++ code"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.3;dashed=1;strokeColor=#9673a6;"
          edge="1" source="llm_outer" target="ctrl_outer" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="265"/>
              <mxPoint x="560" y="305"/>
              <mxPoint x="480" y="305"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Controller → C++ engine (compile + run) -->
        <mxCell id="e4" value="compile + run"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;"
          edge="1" source="ctrl_outer" target="cpp_outer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- C++ engine → Output -->
        <mxCell id="e5" value="stdout"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;"
          edge="1" source="cpp_outer" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output → Controller (error / fix loop) -->
        <mxCell id="e6" value="error log (fix loop)"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.9;dashed=1;strokeColor=#b85450;"
          edge="1" source="output" target="ctrl_outer" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="640"/>
              <mxPoint x="420" y="490"/>
              <mxPoint x="480" y="490"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Output → Web UI (parsed JSON) -->
        <mxCell id="e7" value="parsed JSON"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#b85450;"
          edge="1" source="output" target="webui" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Web UI → User -->
        <mxCell id="e8" value="visualisation"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;dashed=1;strokeColor=#666666;"
          edge="1" source="webui" target="user" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="100" y="625"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- memory.md file → Controller -->
        <mxCell id="e9" value="hot-reloaded"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;strokeColor=#d6b656;dashed=1;"
          edge="1" source="memory_file" target="ctrl_outer" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- static → Web UI -->
        <mxCell id="e10" value=""
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=0;entryX=0.3;entryY=1;strokeColor=#666666;"
          edge="1" source="static" target="webui" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
